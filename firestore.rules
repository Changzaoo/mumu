rules_version = '2';

// Aurial — Firestore security rules (cross-device sync + community trending).
// Paste these into Firebase console → Firestore Database → Rules → Publish.
service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user private data (likes, playlists, library). Only the owner may
    // read or write their own space.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Community trending: public to read (the "em alta" feed); any signed-in
    // user may contribute a like. Note: the like counter is client-incremented,
    // which is fine for a personal app — move to a Cloud Function to fully
    // prevent tampering.
    match /trending/{trackId} {
      allow read: if true;
      allow write: if request.auth != null;

      // One vote doc per user guards double-counting; only its owner touches it.
      match /voters/{uid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Telemetria (página /telemetria do admin): cada usuário escreve apenas o
    // PRÓPRIO doc; somente os admins da allow-list conseguem ler.
    match /telemetry/{uid} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null
        && request.auth.token.email in [
          'perdibitcoin@gmail.com',
          'redcanidsvinicius@gmail.com'
        ];
    }

    // Compartilhamentos por link (/s/:id): qualquer pessoa COM O LINK pode ler
    // (a página funciona sem login); só usuários logados criam, e o doc é
    // imutável depois de criado.
    match /shares/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.byUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Community shared library: link-imported tracks visible to every user.
    // The FIRST sharer owns the entry — only they can update it, and nobody can
    // relabel/reorder someone else's (enforced server-side).
    match /sharedTracks/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.sharedByUid == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.sharedByUid == request.auth.uid
        && request.resource.data.sharedByUid == request.auth.uid
        && request.resource.data.sharedAt == resource.data.sharedAt;
      allow delete: if false;
    }
  }
}
