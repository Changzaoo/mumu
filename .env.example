# ──────────────────────────────────────────────────────────────
# Aurial — environment template
# Copy to apps/api/.env (backend) and apps/web/.env.local (frontend).
# NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────

# ═══ API (apps/api/.env) ═══

NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:5173

# PostgreSQL
DATABASE_URL=postgresql://aurial:aurial@localhost:5432/aurial?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Firebase Admin (service account — Project Settings > Service Accounts)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
# Keep the \n escapes exactly as exported
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Storage: "r2" | "s3" | "supabase" | "local" (local = dev disk storage)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage
# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=aurial-media
R2_PUBLIC_BASE_URL=https://media.yourdomain.com
# Supabase Storage (alternative)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=aurial-media

# Streaming security (HMAC secret for signed stream tokens)
STREAM_TOKEN_SECRET=change-me-64-random-chars

# FFmpeg (leave empty to use PATH)
FFMPEG_PATH=
FFPROBE_PATH=

# Logging: fatal|error|warn|info|debug|trace
LOG_LEVEL=debug

# ═══ WEB (apps/web/.env.local) ═══

VITE_API_URL=http://localhost:4000/api/v1
VITE_WS_URL=http://localhost:4000

# Firebase Web SDK (Project Settings > General > Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ═══ DEPLOY (infra/) ═══

# Linux server on the local network (SSH). Password auth only for bootstrap —
# switch to key-based auth with infra/scripts/setup-ssh-key.sh
DEPLOY_HOST=192.168.0.100
DEPLOY_USER=v
DEPLOY_PATH=/opt/aurial
